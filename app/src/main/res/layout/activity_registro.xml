<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F8F8"
    tools:context=".RegisterActivity">

    <!-- Imagem no canto superior esquerdo -->
    <ImageView
        android:id="@+id/top_image"
        android:layout_width="115dp"
        android:layout_height="123dp"
        android:layout_marginStart="-10dp"
        android:layout_marginTop="-10dp"
        android:contentDescription="Top Decoration"
        android:scaleType="fitXY"
        android:src="@drawable/bolacima"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />


    <TextView
        android:id="@+id/login_text"
        android:layout_width="220dp"
        android:layout_height="52dp"
        android:layout_marginEnd="288dp"
        android:text="      REGISTER"
        android:textColor="#000"
        android:textSize="30sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        tools:ignore="MissingConstraints"
        tools:layout_editor_absoluteY="70dp" />

    <EditText
        android:id="@+id/username_field"
        android:layout_width="420dp"
        android:layout_height="68dp"
        android:layout_marginTop="696dp"
        android:background="@drawable/rounded_edittext"
        android:hint="      Username"
        android:inputType="text"
        android:padding="22dp"
        android:textColor="#000"
        android:textSize="18sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.471"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/login_text" />


    <EditText
        android:id="@+id/password_field"
        android:layout_width="420dp"
        android:layout_height="68dp"
        android:layout_marginTop="64dp"
        android:layout_marginEnd="48dp"
        android:background="@drawable/rounded_edittext"
        android:hint="   Password"
        android:inputType="textPassword"
        android:padding="12dp"
        android:textColor="#000"
        android:textSize="18sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.539"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/username_field" />

    <ImageView
        android:id="@+id/password_lock_icon"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginStart="16dp"
        android:contentDescription="Password Lock Icon"
        android:src="@drawable/cadeado"
        app:layout_constraintBottom_toBottomOf="@id/password_field"
        app:layout_constraintStart_toStartOf="@id/password_field"
        app:layout_constraintTop_toTopOf="@id/password_field" />


    <ImageView
        android:id="@+id/user_icon"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginStart="16dp"
        android:contentDescription="User Icon"
        android:src="@drawable/usuario"
        app:layout_constraintBottom_toBottomOf="@id/username_field"
        app:layout_constraintStart_toStartOf="@id/username_field"
        app:layout_constraintTop_toTopOf="@id/username_field" />

    <ImageView
        android:id="@+id/show_password_icon"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginEnd="216dp"
        android:clickable="true"
        android:contentDescription="Show Password"
        android:focusable="true"
        android:src="@drawable/olho_versenha"
        app:layout_constraintBottom_toBottomOf="@id/password_field"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/password_field" />

    <EditText
        android:id="@+id/email_field"
        android:layout_width="420dp"
        android:layout_height="68dp"
        android:layout_marginTop="568dp"
        android:background="@drawable/rounded_edittext"
        android:hint="   Email"
        android:inputType="textEmailAddress"
        android:paddingStart="50dp"
        android:textColor="#000"
        android:textSize="18sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.471"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/login_text" />

    <ImageView
        android:id="@+id/email_icon"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="8dp"
        android:contentDescription="Email Icon"
        android:src="@drawable/email_icon"
        app:layout_constraintBottom_toBottomOf="@id/email_field"
        app:layout_constraintStart_toStartOf="@id/email_field"
        app:layout_constraintTop_toTopOf="@id/email_field" />


    <Button
        android:id="@+id/login_button"
        android:layout_width="315dp"
        android:layout_height="63dp"
        android:layout_marginTop="56dp"
        android:background="@drawable/rounded_button"
        android:padding="12dp"
        android:text="REGISTER"
        android:textAllCaps="true"
        android:textColor="@android:color/white"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.501"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/password_field" />

    <ImageView
        android:id="@+id/welcome_image"
        android:layout_width="397dp"
        android:layout_height="366dp"
        android:layout_marginTop="148dp"
        android:contentDescription="Illustration"
        android:scaleType="fitCenter"
        android:src="@drawable/imagem_tela_registro"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.501"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/login_text" />

    <ImageView
        android:id="@+id/bottom_image"
        android:layout_width="117dp"
        android:layout_height="131dp"
        android:layout_marginEnd="692dp"
        android:layout_marginBottom="4dp"
        android:contentDescription="Bottom Decoration"
        android:scaleType="fitXY"
        android:src="@drawable/bolabaixo"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
